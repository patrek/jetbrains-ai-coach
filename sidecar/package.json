{
  "name": "ai-coach-sidecar",
  "version": "0.1.0",
  "private": true,
  "description": "Node sidecar for the AI Coach JetBrains plugin: wraps the vendored upstream core in a stdio RPC server.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "chartjs-chart-treemap": "3.1.0",
    "htm": "3.1.1",
    "leo-profanity": "1.9.0",
    "preact": "10.29.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "esbuild": "0.28.0",
    "jsdom": "29.1.1",
    "preact-render-to-string": "6.7.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
