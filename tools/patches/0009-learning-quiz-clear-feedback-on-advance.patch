+// The quiz feedback (explanation + Next button) is rendered as a SEPARATE Preact
+// root into #quiz-feedback and shown imperatively. Re-rendering the quiz card on
+// advance does NOT clear it — the card's own #quiz-feedback vnode is an empty,
+// display:none leaf, so the parent reconciliation leaves the separately-rendered
+// content (and the stale Next button) in place. Tear that root down and re-hide
+// the panel when moving to the next question; otherwise the previous question's
+// feedback stays visible and its old Next button re-renders the current question,
+// which looks like "Next does nothing".
+export function clearQuizFeedback(): void {
+  const feedback = document.getElementById('quiz-feedback');
+  if (feedback) {
+    render(null, feedback);
+    feedback.style.display = 'none';
+  }
+}
