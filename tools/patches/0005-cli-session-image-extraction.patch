     .filter(block => block.type === 'image').length;
 }
 
+function imageBlockToDataUri(block: ClaudeContentBlock): string | null {
+  const source = block.source;
+  if (!source || source.type !== 'base64' || typeof source.data !== 'string' || !source.data) return null;
+  const mediaType = typeof source.media_type === 'string' && source.media_type ? source.media_type : 'image/png';
+  return `data:${mediaType};base64,${source.data}`;
+}
+
+/**
+ * Extract inline screenshots from a Claude CLI session file (`cli-events` source
+ * kind) for one request. Claude stores images as content blocks
+ * `{ type: 'image', source: { type: 'base64', media_type, data } }` and the
+ * request id is the line `uuid`. Returns base64 data URIs, capped at 4 per
+ * request to bound memory — mirroring the VS Code path's `extractSessionImages`.
+ *
+ * The VS Code extractor cannot read these: both harnesses use `.jsonl`, but the
+ * VS Code format is a `kind: 0/2` state log while Claude is one turn per line, so
+ * `getSessionImages` must dispatch on `SessionSource.kind`.
+ */
+export function extractCliSessionImages(filePath: string, requestId: string): string[] {
+  try {
+    assertTrustedPath(filePath);
+    const raw = readFileSafe(filePath);
+    if (raw === null) return [];
+    for (const line of raw.split('\n')) {
+      const trimmed = line.trim();
+      if (!trimmed || !trimmed.includes(requestId)) continue;
+      let entry: ClaudeLine;
+      try { entry = JSON.parse(trimmed) as ClaudeLine; } catch { continue; }
+      if (entry.uuid !== requestId) continue;
+      const images: string[] = [];
+      for (const block of toContentArray(entry.message?.content)) {
+        if (block.type !== 'image') continue;
+        const uri = imageBlockToDataUri(block);
+        if (uri) images.push(uri);
+        if (images.length >= 4) break;
+      }
+      return images;
+    }
+    return [];
+  } catch (e) {
+    warnCore('parser-claude', `Failed to extract images from ${filePath}: ${e instanceof Error ? e.message : String(e)}`);
+    return [];
+  }
+}
+
 function applyClaudeToolBlock(
