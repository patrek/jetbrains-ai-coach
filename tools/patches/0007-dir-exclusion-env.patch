 type WorkspaceMap = Map<string, Workspace>;
 
+// Fork divergence (JetBrains port, part 7): drop directories the IDE host
+// excluded via the AI_COACH_EXCLUDED_DIRS env var (platform-path-separator
+// joined). A directory is excluded when it equals an excluded root or is nested
+// under one. Mirrors the sidecar's src/dir-exclusion.ts; inlined here so the
+// vendored tree stays self-contained (no import out of vendor/).
+function excludeScannedDirs(dirs: string[]): string[] {
+  const raw = process.env.AI_COACH_EXCLUDED_DIRS;
+  if (!raw || !raw.trim()) return dirs;
+  const roots = raw.split(path.delimiter).map(s => s.trim()).filter(Boolean).map(s => path.resolve(s));
+  if (roots.length === 0) return dirs;
+  return dirs.filter(dir => {
+    const normalized = path.resolve(dir);
+    return !roots.some(root => normalized === root || normalized.startsWith(root + path.sep));
+  });
+}
